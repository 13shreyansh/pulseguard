OPENAI_API_KEY=
# Pulse's incident brief and evidence paths use gpt-5.6-sol with the gpt-5.6 alias
# as the only compatibility fallback. This is intentionally not configurable to GPT-4.
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=low
OPENAI_FINAL_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_IMAGE_MODEL=gpt-image-2

VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
PULSE_CALL_PROVIDER=vapi
PULSE_VAPI_ASSISTANT_ID=
PULSE_VAPI_USE_SAVED_ASSISTANT=
PULSE_VAPI_MODEL=gpt-4o-mini
PULSE_VAPI_VOICE_ID=Elliot
PULSE_VAPI_RING_TIMEOUT_SECONDS=30
PULSE_VAPI_MAX_DURATION_SECONDS=90
PULSE_REQUIRE_INTERACTIVE_CALL=true
# Controlled prototype calls route only through this authorized response line.
# If unset, Pulse falls back to PULSE_OPERATOR_PHONE / PULSE_RECEIVING_PHONE.
PULSE_COORDINATION_PHONE=
PULSE_OPERATOR_PHONE=
# Legacy alias still accepted during migration.
PULSE_RECEIVING_PHONE=

TWILIO_ACCOUNT_SID=
# Optional preferred scoped credentials.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_FROM_NUMBER=
PULSE_MESSAGE_WEBHOOK_URL=
PULSE_MESSAGE_WEBHOOK_TOKEN=

PULSE_DISPATCH_MODE=live
# Required in production for dispatch and status tokens.
PULSE_DISPATCH_SESSION_SECRET=
# Required to authorize one outbound controlled-desk attempt. Share privately with judges.
PULSE_DEMO_ACCESS_CODE=
# Optional durable rate-limit store. Falls back to per-instance memory locally.
PULSE_RATE_LIMIT_REDIS_URL=
PULSE_RATE_LIMIT_REDIS_TOKEN=

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

ADAPTION_LABS_API_KEY=
ADAPTION_API_KEY=
PULSE_OPS_TOKEN=
